    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@faapi/faapi": "workspace:*",
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "3",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@faapi/faapi": "workspace:*",
    "typescript": ">=5.7.0",
    "zod": "^4.4.3"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/faapi/faapi.git",
    "directory": "packages/mcp"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/index.js",
