{
  "name": "@faapi/faapi",
  "version": "0.0.0-canary.0",
  "description": "函数即接口 - Function as API",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "bin": {
    "faapi": "./dist/cli/index.js"
  },
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "NODE_OPTIONS=--max-old-space-size=8192 vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "esbuild": "^0.25.0",
    "fast-glob": "^3.3.3",
    "typescript": "^5.7.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "3",
    "cac": "^6.7.14",
    "chokidar": "^4.0.3",
    "tsup": "^8.4.0",
    "vitest": "^3.1.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "zod": "^4.4.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/faapi/faapi.git",
    "directory": "packages/faapi"
  },
  "bugs": {
    "url": "https://github.com/faapi/faapi/issues"
  },
  "keywords": [
    "api",
    "framework",
    "typescript",
    "nodejs",
    "middleware",
    "ast",
    "function-as-api"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  }
}
